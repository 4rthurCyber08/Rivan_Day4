### NAT/PAT

~~~
!@UTM-PH
conf t
 int g1
  ip nat outside
 int g3
  ip nat inside
  exit
  !
 no ip access-list extended NAT
 ip access-list extended NAT
  permit ip 10.11.11.96 0.0.0.31 any
  !
 ip nat inside source list NAT int g1 overload
 !
 ip route 0.0.0.0 0.0.0.0 208.8.8.2
 end
~~~


